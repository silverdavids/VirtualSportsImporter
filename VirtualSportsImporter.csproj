    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>VirtualSportsImporter.Worker</AssemblyName>
    <RootNamespace>VirtualSportsImporter.Worker</RootNamespace>
    <UserSecretsId>dotnet-VirtualSportsImporter-8083521a-9a52-4762-a1b2-0c0ce24fcb74</UserSecretsId>
